rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and update their own profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow admins to read all profiles
      allow read: if request.auth != null && request.auth.token.email == 'praveenks15326@gmail.com';
    }
    
    // Sessions: Users see their own, admins see all
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow read, write: if request.auth != null && request.auth.token.email == 'praveenks15326@gmail.com';
    }
    
    // Snapshots: linked to sessions
    match /snapshots/{snapshotId} {
      allow read, write: if request.auth != null;
    }
    
    // Assignments: Authenticated users can read, admins can write
    match /assignments/{assignmentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'praveenks15326@gmail.com';
    }
    
    // Resume Analysis
    match /resume_analysis/{analysisId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow read: if request.auth != null && request.auth.token.email == 'praveenks15326@gmail.com';
    }
  }
}
